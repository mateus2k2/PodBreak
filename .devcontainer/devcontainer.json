{
	"name": "Whisper",
	"build": {
		"dockerfile": "Dockerfile",
		"args": {
			"VARIANT": "20"
		}
	},
	"remoteUser": "vscode",
	"runArgs": [
		"--name", "whisper_devcontainer",
		"--gpus", "all",
		"--network=host"
	],
	"customizations": {
		"vscode": {
			"settings": {
				"terminal.integrated.defaultProfile.linux": "bash"
			}
		}
	},
	"mounts": [	],
	"forwardPorts": [
		3000,
		3333,
		5001,
		5010
	],
	"postCreateCommand": "bash .devcontainer/post-create.sh"
}